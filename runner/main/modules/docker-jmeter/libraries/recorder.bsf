import java.util.*;
import java.io.*;
import org.apache.jmeter.util.JMeterUtils;

List header = new ArrayList();
header.add("runId");
header.add("timestamp");
header.add("label");
header.add("samples");
header.add("errors");
header.add("average");
header.add("min");
header.add("max");
header.add("90th");
header.add("dbread");
header.add("dbwrite");
header.add("dbtime");
header.add("memory");
header.add("files");
header.add("load");

// Files are relative to the execution directory
String resultsFile = "results.csv";
String runsFile = "runs.csv";
String resultsHeader = "";

// Check if header needs to be written
if (!(new File(resultsFile).exists())) {
    for (int i = 0; i < header.size(); i++) {
        resultsHeader += header.get(i);
        if (i < header.size() - 1) {
            resultsHeader += ",";
        }
    }
    writeLineToCsv(resultsFile, resultsHeader);
}

// Get the variables
String runId = vars.get("runtimestamp");
