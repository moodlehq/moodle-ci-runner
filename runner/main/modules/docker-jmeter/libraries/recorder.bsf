// Build the CSV line
StringBuilder line = new StringBuilder();
line.append(runId).append(",");
line.append(timestamp).append(",");
line.append(label).append(",");
line.append(samples).append(",");
line.append(errors).append(",");
line.append(average).append(",");
line.append(min).append(",");
line.append(max).append(",");
line.append(ninetieth).append(",");
line.append(dbread).append(",");
line.append(dbwrite).append(",");
line.append(dbtime).append(",");
