String samples = String.valueOf(sampleResult.getSampleCount());
String errors = String.valueOf(sampleResult.getErrorCount());
String average = String.valueOf(sampleResult.getTime());
// Assuming single sample results, min/max/90th are the same as time
String min = String.valueOf(sampleResult.getTime());
String max = String.valueOf(sampleResult.getTime());
String ninetieth = String.valueOf(sampleResult.getTime());

// Variables from Moodle response headers (if available)
// You might need to adjust logic here if these headers aren't always present
String dbread = "0";
String dbwrite = "0";
String dbtime = "0";
String memory = "0";
String files = "0";
String load = "0";

